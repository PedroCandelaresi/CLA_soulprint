{
    "name": "demo2-monorepo",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "build": "turbo run build",
        "compose:config": "docker compose -f infra/docker/docker-compose.yml config",
        "dev": "turbo run dev",
        "lint": "turbo run lint",
        "start": "turbo run start",
        "clean": "rm -rf .turbo apps/*/.next apps/*/dist",
        "validate": "pnpm lint && pnpm build"
    },
    "devDependencies": {
        "turbo": "2.7.1",
        "prettier": "3.7.4"
    },
    "packageManager": "pnpm@9.0.0",
    "engines": {
        "node": ">=18"
    }
}
