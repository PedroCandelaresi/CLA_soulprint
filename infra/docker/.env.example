# ============================================================================
# Deploy Environment Variables
# Copy this file to .env and fill in the values
# ============================================================================

# Database
MYSQL_ROOT_PASSWORD=change_me_strong_password
DB_NAME=vendure
DB_USER=vendure
DB_PASSWORD=vendure

# Vendure
NODE_ENV=production
APP_ENV=production
DB_SYNCHRONIZE=false
PORT=3001

# Admin
SUPERADMIN_USERNAME=admin_change_me
SUPERADMIN_PASSWORD=change_me_strong_password

# Security
COOKIE_SECRET=change_me_32_chars_minimum_length
CORS_ORIGINS=https://yourdomain.com
COOKIE_DOMAIN=
COOKIE_SAME_SITE=lax
COOKIE_SECURE=true
COOKIE_SECURE_PROXY=true

# URLs
SHOP_PUBLIC_URL=https://yourdomain.com
NEXT_PUBLIC_VENDURE_API_URL=https://yourdomain.com/shop-api
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_ANDREANI_ENABLED=false

# Customer accounts / Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://yourdomain.com/api/auth/google/callback

# Email
# Requerido si querés que el alta por email/password funcione end-to-end:
# el registro manda un mail de verificación y recién después habilita el pago.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SECURE=false
OPERATIONS_NOTIFICATION_EMAIL=

# ============================================================================
# Getnet Payment Configuration
# ============================================================================
GETNET_ENABLED=true
GETNET_MODE=real
GETNET_MOCK_FORCE_STATUS=interactive

# Standalone server port (matches backend Vendure port for nginx compatibility)
GETNET_PORT=4003

# Internal API URL for frontend communication with Getnet standalone server
GETNET_INTERNAL_API_URL=http://getnet:4003/payments/getnet

# API Base URLs (development)
GETNET_AUTH_BASE_URL=https://auth.preprod.geopagos.com
GETNET_CHECKOUT_BASE_URL=https://api-santander.preprod.geopagos.com

# API Credentials (from Getnet/Santander developer portal)
GETNET_CLIENT_ID=your_client_id
GETNET_CLIENT_SECRET=your_client_secret
GETNET_SCOPE=*
GETNET_CURRENCY=032

# Webhook URL (use ngrok/localtunnel for local testing)
GETNET_WEBHOOK_URL=

# Redirect URLs (Where user goes after payment)
GETNET_SUCCESS_URL=https://yourdomain.com/checkout/success
GETNET_FAILED_URL=https://yourdomain.com/checkout/failed

# Order expiration in minutes (default: 10)
GETNET_EXPIRE_LIMIT_MINUTES=10

# Request timeout in milliseconds (default: 30000)
GETNET_REQUEST_TIMEOUT=30000

# Personalization uploads
PERSONALIZATION_MAX_FILE_SIZE_MB=10
PERSONALIZATION_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ============================================================================
# Andreani logistics configuration
# ============================================================================
ANDREANI_ENABLED=false
ANDREANI_MODE=mock
ANDREANI_ENVIRONMENT=production
# Base URL del cotizador (sobreescribible si Andreani cambia el dominio)
ANDREANI_BASE_URL=
ANDREANI_AUTH_TOKEN=
ANDREANI_TIMEOUT_MS=15000
ANDREANI_SHIPMENT_BASE_URL=
ANDREANI_CONTRACT_CODE=
ANDREANI_CLIENT_CODE=
ANDREANI_DEFAULT_CATEGORY_ID=
ANDREANI_ORIGIN_POSTAL_CODE=
ANDREANI_ORIGIN_CITY=
ANDREANI_ORIGIN_PROVINCE=
ANDREANI_ORIGIN_COUNTRY=
ANDREANI_ORIGIN_ADDRESS=
