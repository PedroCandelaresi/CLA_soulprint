# ============================================================================
# Deploy Environment Variables
# Copy this file to .env and fill in the values
# ============================================================================

# Database
MYSQL_ROOT_PASSWORD=change_me_strong_password
DB_NAME=vendure
DB_USER=vendure
DB_PASSWORD=vendure

# Vendure
NODE_ENV=production
APP_ENV=dev
DB_SYNCHRONIZE=false
PORT=3001

# Admin
SUPERADMIN_USERNAME=admin_change_me
SUPERADMIN_PASSWORD=change_me_strong_password

# Security
COOKIE_SECRET=change_me_32_chars_minimum_length
CORS_ORIGINS=https://yourdomain.com
COOKIE_DOMAIN=
COOKIE_SAME_SITE=lax
COOKIE_SECURE=true
COOKIE_SECURE_PROXY=true

# URLs
SHOP_PUBLIC_URL=https://yourdomain.com
NEXT_PUBLIC_VENDURE_API_URL=https://yourdomain.com/shop-api
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SECURE=false

# ============================================================================
# Getnet Payment Configuration
# ============================================================================
GETNET_ENABLED=false

# Standalone server port (matches backend Vendure port for nginx compatibility)
GETNET_PORT=4002

# API Base URLs (development)
GETNET_AUTH_BASE_URL=https://auth.preprod.geopagos.com
GETNET_CHECKOUT_BASE_URL=https://api-santander.preprod.geopagos.com

# API Credentials (from Getnet/Santander developer portal)
GETNET_CLIENT_ID=your_client_id
GETNET_CLIENT_SECRET=your_client_secret
GETNET_SCOPE=*
GETNET_CURRENCY=032

# Webhook URL (use ngrok/localtunnel for local testing)
GETNET_WEBHOOK_URL=

# Redirect URLs (Where user goes after payment)
GETNET_SUCCESS_URL=https://yourdomain.com/checkout/success
GETNET_FAILED_URL=https://yourdomain.com/checkout/failed

# Order expiration in minutes (default: 10)
GETNET_EXPIRE_LIMIT_MINUTES=10

# Request timeout in milliseconds (default: 30000)
GETNET_REQUEST_TIMEOUT=30000
