# Backend URL for Server Side fetching (Docker network)
VENDURE_INTERNAL_API_URL=http://backend:3001/shop-api

# Backend URL for Client Side fetching / Images (Browser)
NEXT_PUBLIC_VENDURE_API_URL=http://localhost:4001/shop-api

# Getnet Checkout API URL (Client-side uses this)
# Defaults to local Next.js API routes which proxy to standalone server
NEXT_PUBLIC_GETNET_API_URL=/api/payments/getnet

# Note: GETNET_INTERNAL_API_URL is defined in backend/.env and shared
# It points to the standalone Getnet server (default: http://localhost:4003/payments/getnet)

# Site URL for building absolute URLs (success/failure redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shared auth/session settings for server-side auth routes
COOKIE_SECRET=change_me_32_chars_min
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
