{{> header title="Confirmá tu cuenta" }}

<mj-section background-color="#ffffff" padding="0 32px 8px">
  <mj-column>
    <mj-text font-size="18px" line-height="1.8" padding="0 0 16px">
      Hola,
    </mj-text>
    <mj-text font-size="17px" line-height="1.8" padding="0 0 16px">
      Recibimos tu registro en <strong>{{ brandName }}</strong>. Para activar tu cuenta y empezar a comprar, confirmá tu dirección de correo haciendo clic en el botón.
    </mj-text>
  </mj-column>
</mj-section>

<mj-section background-color="#f5f5f5" padding="6px 32px 6px">
  <mj-column>
    <mj-text
      align="center"
      color="#424242"
      font-size="15px"
      font-weight="600"
      line-height="1.5"
      padding="16px 16px 4px"
    >
      ¿Cómo funciona?
    </mj-text>
    <mj-text align="center" color="#424242" font-size="15px" line-height="1.8" padding="0 10px 4px">
      1 — Hacé clic en el botón de abajo
    </mj-text>
    <mj-text align="center" color="#424242" font-size="15px" line-height="1.8" padding="0 10px 4px">
      2 — Tu cuenta queda activada
    </mj-text>
    <mj-text align="center" color="#424242" font-size="15px" line-height="1.8" padding="0 10px 16px">
      3 — Ya podés ingresar y comprar
    </mj-text>
  </mj-column>
</mj-section>

<mj-section background-color="#ffffff" padding="24px 32px 0">
  <mj-column>
    <mj-button
      href="{{ verifyEmailAddressUrl }}?token={{ verificationToken }}"
      background-color="#1a1a1a"
      color="#ffffff"
      align="center"
      padding="0 0 20px"
    >
      Activar mi cuenta
    </mj-button>
    <mj-text css-class="me-muted" align="center" font-size="15px" line-height="1.8" padding="0 0 6px">
      Si el botón no abre, copiá y pegá este enlace en tu navegador:
    </mj-text>
    <mj-text css-class="me-link" align="center" font-size="14px" line-height="1.8" padding="0">
      <a href="{{ verifyEmailAddressUrl }}?token={{ verificationToken }}" style="color:#1a1a1a;word-break:break-all;">
        {{ verifyEmailAddressUrl }}?token={{ verificationToken }}
      </a>
    </mj-text>
  </mj-column>
</mj-section>

<mj-section background-color="#ffffff" padding="20px 32px 0">
  <mj-column>
    <mj-text css-class="me-muted" font-size="15px" line-height="1.8" padding="0 0 16px">
      Si no intentaste crear esta cuenta, podés ignorar este correo sin problema.
    </mj-text>
  </mj-column>
</mj-section>

{{> footer }}
