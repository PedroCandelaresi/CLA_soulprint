<mjml>
  <mj-head>
    <mj-title>{{ title }}</mj-title>
    <mj-preview>{{ title }}</mj-preview>
    <mj-attributes>
      <mj-all font-family="'Helvetica Neue', Helvetica, Arial, sans-serif" />
      <mj-text color="#212121" font-size="17px" line-height="1.7" />
      <mj-button
        font-size="16px"
        font-weight="600"
        line-height="1.2"
        border-radius="8px"
        inner-padding="16px 32px"
      />
      <mj-section padding="0" />
      <mj-column padding="0" />
    </mj-attributes>
    <mj-style inline="inline">
      .me-card {
        border-radius: 16px;
      }
      .me-title div {
        letter-spacing: -0.01em;
      }
      .me-muted div,
      .me-muted a {
        color: #757575 !important;
      }
      .me-link a {
        color: #212121 !important;
        text-decoration: underline;
      }
    </mj-style>
  </mj-head>

  <mj-body background-color="#f5f5f5" width="640px">

    <!-- Header -->
    <mj-section background-color="#1a1a1a" padding="0">
      <mj-column padding="28px 24px 24px">
        {{#if brandLogoUrl}}
          <mj-image
            src="{{ brandLogoUrl }}"
            alt="{{ brandName }}"
            width="180px"
            align="center"
            padding="0"
          />
        {{else}}
          <mj-text
            align="center"
            color="#ffffff"
            font-size="22px"
            font-weight="700"
            letter-spacing="0.05em"
            padding="4px 0"
          >
            {{ brandName }}
          </mj-text>
        {{/if}}
      </mj-column>
    </mj-section>

    <!-- Card start -->
    <mj-section padding="28px 16px 0" background-color="#f5f5f5">
      <mj-column background-color="#ffffff" border-radius="16px" padding="0" css-class="me-card">
        <mj-text
          css-class="me-title"
          font-size="26px"
          font-weight="700"
          line-height="1.25"
          align="center"
          color="#111111"
          padding="36px 32px 12px"
        >
          {{ title }}
        </mj-text>
      </mj-column>
    </mj-section>
