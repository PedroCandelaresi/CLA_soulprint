        <mj-section background-color="#ffffff" padding="4px 32px 0">
          <mj-column>
            <mj-divider border-color="#e0e0e0" border-width="1px" padding="0" />
          </mj-column>
        </mj-section>

        <mj-section background-color="#ffffff" padding="18px 32px 36px">
          <mj-column>
            <mj-text css-class="me-muted" align="center" font-size="15px" line-height="1.7" padding="0 0 8px">
              Si necesitás ayuda, podés escribirnos respondiendo este correo.
            </mj-text>
            {{#if shopUrl}}
              <mj-text align="center" font-size="15px" font-weight="600" padding="0 0 8px">
                <a href="{{ shopUrl }}" style="color:#1a1a1a;text-decoration:none;">Ir a la tienda</a>
              </mj-text>
            {{/if}}
            <mj-text css-class="me-muted" align="center" font-size="14px" line-height="1.6" padding="0">
              Este correo fue enviado por {{ brandName }}.
            </mj-text>
          </mj-column>
        </mj-section>

  </mj-body>
</mjml>
