{
    "compilerOptions": {
        "module": "commonjs",
        "target": "es2019",
        "lib": [
            "es2019"
        ],
        "sourceMap": true,
        "baseUrl": ".",
        "outDir": "dist",
        "strict": true,
        "skipLibCheck": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "esModuleInterop": true,
        "types": ["node", "jest"]
    },
    "include": [
        "src/**/*"
    ]
}