APP_ENV=local
PORT=3001
DB_HOST=localhost
DB_PORT=3306
DB_NAME=vendure
DB_USER=vendure
DB_PASSWORD=vendure
SUPERADMIN_USERNAME=admin_change_me
SUPERADMIN_PASSWORD=change_me_strong_password
COOKIE_SECRET=change_me_32_chars_min
CORS_ORIGINS=http://localhost:3000,http://localhost:4000
COOKIE_DOMAIN=
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false
COOKIE_SECURE_PROXY=false
ASSET_URL_PREFIX=/assets/
SHOP_PUBLIC_URL=http://localhost:4000
# Debe apuntar al storefront público. Se usa para links de verificación, reset y cambio de email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SECURE=false
OPERATIONS_NOTIFICATION_EMAIL=
# En testing/production completá SMTP_* para que funcionen los emails de activación de cuenta.
# Solo para desarrollo local/efimero. En testing/production persistente debe quedar en false y usarse migraciones.
DB_SYNCHRONIZE=true

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ============================================================================
# Getnet Checkout (Santander / GeoPagos) - Development
# ============================================================================
# Set to true to enable Getnet payment endpoints
GETNET_ENABLED=true
GETNET_MODE=real
GETNET_MOCK_FORCE_STATUS=interactive

# Standalone server port (if using standalone server mode)
GETNET_PORT=4003

# Getnet Internal API URL (used by frontend to communicate with standalone server)
GETNET_INTERNAL_API_URL=http://localhost:4003/payments/getnet

# Getnet API Base URLs (Development)
GETNET_AUTH_BASE_URL=https://auth.preprod.geopagos.com
GETNET_CHECKOUT_BASE_URL=https://api-santander.preprod.geopagos.com

# Getnet Credentials (Get from GeoPagos/Santander developer portal)
GETNET_CLIENT_ID=your_client_id
GETNET_CLIENT_SECRET=your_client_secret
GETNET_SCOPE=*

# Payment Configuration
GETNET_CURRENCY=032

# Webhook URL (Use ngrok/localtunnel for local testing)
# Example: https://abc123.ngrok.io/payments/getnet/webhook
GETNET_WEBHOOK_URL=

# Redirect URLs (Where user goes after payment)
GETNET_SUCCESS_URL=http://localhost:3000/checkout/success
GETNET_FAILED_URL=http://localhost:3000/checkout/failed

# Order expiration in minutes (default: 10)
GETNET_EXPIRE_LIMIT_MINUTES=10

# Request timeout in milliseconds (default: 30000)
GETNET_REQUEST_TIMEOUT=30000

# Personalization uploads
PERSONALIZATION_MAX_FILE_SIZE_MB=10
PERSONALIZATION_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ============================================================================
# Andreani logistics
# ============================================================================
# Testing recomendado: ANDREANI_ENABLED=true + ANDREANI_MODE=mock
ANDREANI_ENABLED=false
ANDREANI_MODE=mock
ANDREANI_ENVIRONMENT=production
ANDREANI_BASE_URL=
ANDREANI_AUTH_TOKEN=
ANDREANI_TIMEOUT_MS=15000
ANDREANI_SHIPMENT_BASE_URL=
ANDREANI_CONTRACT_CODE=
ANDREANI_CLIENT_CODE=
ANDREANI_DEFAULT_CATEGORY_ID=
ANDREANI_ORIGIN_POSTAL_CODE=
ANDREANI_ORIGIN_CITY=
ANDREANI_ORIGIN_PROVINCE=
ANDREANI_ORIGIN_COUNTRY=
ANDREANI_ORIGIN_ADDRESS=
