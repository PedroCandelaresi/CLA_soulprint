APP_ENV=local
PORT=3001
DB_HOST=localhost
DB_PORT=3306
DB_NAME=vendure
DB_USER=vendure
DB_PASSWORD=vendure
SUPERADMIN_USERNAME=admin_change_me
SUPERADMIN_PASSWORD=change_me_strong_password
COOKIE_SECRET=change_me_32_chars_min
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
COOKIE_DOMAIN=
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false
COOKIE_SECURE_PROXY=false
ASSET_URL_PREFIX=/assets/
SHOP_PUBLIC_URL=http://localhost:3000
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SECURE=false
RUN_JOB_QUEUE_IN_MAIN_PROCESS=true
# Solo para desarrollo local/efimero. En testing/production persistente debe quedar en false y usarse migraciones.
DB_SYNCHRONIZE=true

# ── Personalization (upload de archivo de medalla post-pago) ────────────────
PERSONALIZATION_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf
PERSONALIZATION_MAX_FILE_SIZE_MB=10
