{
    "name": "backend",
    "version": "1.0.0",
    "packageManager": "pnpm@9.0.0",
    "scripts": {
        "start": "ts-node src/bootstrap/index.ts",
        "start:server": "ts-node src/bootstrap/index.ts",
        "start:prod": "node dist/bootstrap/index.js",
        "build": "tsc && node dist/admin-ui/build.js",
        "build:admin-ui": "node dist/admin-ui/build.js",
        "dev": "ts-node-dev --respawn --transpile-only src/bootstrap/index.ts",
        "start:getnet": "ts-node src/plugins/payments/getnet/server.ts",
        "start:getnet:prod": "node dist/plugins/payments/getnet/server.js",
        "dev:getnet": "ts-node-dev --respawn --transpile-only src/plugins/payments/getnet/server.ts",
        "populate": "ts-node src/seed/populate.ts",
        "populate:prod": "node dist/seed/populate.js",
        "currency:enforce-ars": "ts-node src/scripts/enforce-ars-currency.ts",
        "migration:generate": "ts-node src/migrations/generate-migration.ts",
        "migration:run": "ts-node src/migrations/run-migrations.ts",
        "migration:run:prod": "node dist/migrations/run-migrations.js",
        "migration:revert": "ts-node src/migrations/revert-last-migration.ts",
        "migration:revert:prod": "node dist/migrations/revert-last-migration.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage"
    },
    "dependencies": {
        "@nestjs/common": "^10.3.10",
        "@nestjs/platform-express": "^10.3.10",
        "@vendure/admin-ui-plugin": "^2.2.0",
        "@vendure/asset-server-plugin": "^2.2.0",
        "@vendure/core": "^2.2.0",
        "@vendure/email-plugin": "^2.2.0",
        "axios": "^1.6.7",
        "bcrypt": "^5.1.0",
        "dotenv": "^16.4.1",
        "graphql": "^16.9.0",
        "multer": "^1.4.5-lts.2",
        "mysql2": "^3.9.0",
        "reflect-metadata": "^0.1.13",
        "typeorm": "0.3.19"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.12",
        "@types/multer": "^1.4.12",
        "@types/node": "^20.11.0",
        "@vendure/ui-devkit": "^2.2.0",
        "jest": "^29.7.0",
        "ts-node": "^10.9.2",
        "ts-jest": "^29.4.6",
        "ts-node-dev": "^2.0.0",
        "typescript": "5.4.2",
        "yaml": "2.4.2"
    }
}
