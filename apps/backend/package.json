{
    "name": "backend",
    "version": "1.0.0",
    "scripts": {
        "prepare:admin-ui": "node scripts/prepare-admin-ui.js",
        "start": "pnpm run prepare:admin-ui && ts-node src/bootstrap/index.ts",
        "start:server": "pnpm run prepare:admin-ui && ts-node src/bootstrap/index.ts",
        "start:prod": "node dist/bootstrap/index.js",
        "build": "pnpm run prepare:admin-ui && tsc",
        "dev": "pnpm run prepare:admin-ui && ts-node-dev --respawn --transpile-only src/bootstrap/index.ts",
        "populate": "ts-node src/seed/populate.ts",
        "populate:prod": "node dist/seed/populate.js",
        "migration:generate": "ts-node src/migrations/generate-migration.ts",
        "migration:run": "ts-node src/migrations/run-migrations.ts",
        "migration:run:prod": "node dist/migrations/run-migrations.js",
        "migration:revert": "ts-node src/migrations/revert-last-migration.ts",
        "migration:revert:prod": "node dist/migrations/revert-last-migration.js"
    },
    "dependencies": {
        "@nestjs/common": "~10.3.10",
        "@nestjs/graphql": "^12.2.2",
        "@nestjs/platform-express": "^10.3.10",
        "@vendure/admin-ui-plugin": "^2.2.0",
        "@vendure/asset-server-plugin": "^2.2.0",
        "@vendure/common": "^2.2.0",
        "@vendure/core": "^2.2.0",
        "@vendure/email-plugin": "^2.2.0",
        "@vendure/ui-devkit": "^2.3.4",
        "bcrypt": "^5.1.0",
        "dotenv": "^16.4.1",
        "graphql-tag": "^2.12.6",
        "multer": "^1.4.5-lts.2",
        "mysql2": "^3.9.0",
        "reflect-metadata": "^0.1.13",
        "ts-node": "^10.9.2",
        "typeorm": "0.3.19",
        "typescript": "5.4.5"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/multer": "^1.4.12",
        "@types/node": "^20.11.0",
        "ts-node-dev": "^2.0.0"
    }
}
